---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  schema?: Record<string, unknown>;
  breadcrumbs?: { label: string; href: string }[];
}

const { title, description, ogImage = '/images/og-default.png', canonicalUrl, type = 'website', schema, breadcrumbs } = Astro.props;
const siteTitle = 'IsItAuDHD';
const fullTitle = title === 'Home' ? `${siteTitle} — Autism + ADHD Quizzes & Resources` : `${title} | ${siteTitle}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteTitle} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Self-hosted fonts preload -->
    <link rel="preload" href="/fonts/dm-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/dm-sans-600.woff2" as="font" type="font/woff2" crossorigin />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Analytics (Umami - privacy-friendly, no cookies) -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="placeholder-setup-required"></script>

    <!-- Dark mode: prevent flash -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    {/* Schema markup */}
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    {/* Website schema on all pages */}
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": siteTitle,
      "url": "https://isitaudhd.com",
      "description": "Free AuDHD quizzes and resources for understanding the autism + ADHD overlap.",
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to main content
    </a>
    <Header />
    <main id="main-content" class="flex-1" role="main">
      {breadcrumbs && breadcrumbs.length > 0 && (
        <Breadcrumbs items={breadcrumbs} />
      )}
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
const navLinks = [
  { href: '/quiz/', label: 'Quizzes' },
  { href: '/learn/', label: 'Learn' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
];
---

<header class="glass border-b border-border/60 sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-2 group">
      <span class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-lg font-bold leading-none" aria-hidden="true">∞</span>
      <span class="text-lg font-bold text-text group-hover:text-primary transition-colors">IsItAuDHD</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a href={link.href} class="px-3.5 py-2 text-sm font-medium text-text-light hover:text-text hover:bg-muted rounded-[--radius-md] transition-all">
          {link.label}
        </a>
      ))}

      <div class="w-px h-5 bg-border mx-2"></div>

      <button
        id="theme-toggle"
        class="w-9 h-9 flex items-center justify-center text-text-light hover:text-text hover:bg-muted rounded-[--radius-md] transition-all"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <svg class="w-[18px] h-[18px] dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
        <svg class="w-[18px] h-[18px] hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
      </button>

      <a href="/quiz/is-it-audhd/" class="btn-primary !py-2 !px-5 text-sm ml-2">
        Take the Quiz
      </a>
    </div>

    <!-- Mobile buttons -->
    <div class="flex items-center gap-1 md:hidden">
      <button
        id="theme-toggle-mobile"
        class="w-9 h-9 flex items-center justify-center text-text-light hover:text-text rounded-[--radius-md] transition-colors"
        aria-label="Toggle dark mode"
      >
        <svg class="w-[18px] h-[18px] dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
        <svg class="w-[18px] h-[18px] hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
      </button>
      <button
        id="mobile-menu-btn"
        class="w-9 h-9 flex items-center justify-center text-text-light hover:text-text rounded-[--radius-md] transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border/60 bg-surface">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <a href={link.href} class="block px-3 py-2.5 text-text-light hover:text-text hover:bg-muted rounded-[--radius-md] font-medium transition-all">
          {link.label}
        </a>
      ))}
      <div class="pt-2">
        <a href="/quiz/is-it-audhd/" class="btn-primary w-full text-center text-sm !py-3">
          Take the Quiz
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  }
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);
</script>

---
interface Props {
  title: string;
  description: string;
  href: string;
  estimatedTime: string;
  questionCount: number;
  emoji?: string;
  featured?: boolean;
}

const { title, description, href, estimatedTime, questionCount, emoji = '🧠', featured = false } = Astro.props;
---

<a
  href={href}
  class:list={[
    'block bg-surface rounded-[--radius-xl] p-6 border-2 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md group',
    featured ? 'border-primary/30 hover:border-primary' : 'border-border hover:border-primary/40',
  ]}
>
  <div class="text-3xl mb-3">{emoji}</div>
  <h3 class="text-lg font-semibold text-text group-hover:text-primary transition-colors">
    {title}
  </h3>
  <p class="text-text-light text-sm mt-2 leading-relaxed">
    {description}
  </p>
  <div class="flex items-center gap-3 mt-4 text-xs text-text-light">
    <span>{questionCount} questions</span>
    <span class="w-1 h-1 rounded-full bg-border"></span>
    <span>{estimatedTime}</span>
  </div>
</a>

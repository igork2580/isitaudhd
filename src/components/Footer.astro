---
const year = new Date().getFullYear();
---

<footer class="border-t border-border mt-8">
  <div class="max-w-2xl mx-auto px-5 py-8">
    <div class="flex flex-col sm:flex-row justify-between gap-6">
      <div>
        <p class="text-xs font-semibold text-text">IsItAuDHD</p>
        <p class="mt-1 text-[11px] text-text-light max-w-[200px] leading-relaxed">
          Free quizzes and resources for the autism + ADHD overlap.
        </p>
      </div>
      <div class="flex gap-8 text-[11px]">
        <div class="space-y-1.5">
          <a href="/quiz/" class="block text-text-light hover:text-text transition-colors">Quizzes</a>
          <a href="/learn/" class="block text-text-light hover:text-text transition-colors">Learn</a>
          <a href="/blog/" class="block text-text-light hover:text-text transition-colors">Blog</a>
        </div>
        <div class="space-y-1.5">
          <a href="/about/" class="block text-text-light hover:text-text transition-colors">About</a>
          <a href="/disclaimer/" class="block text-text-light hover:text-text transition-colors">Disclaimer</a>
          <a href="/privacy/" class="block text-text-light hover:text-text transition-colors">Privacy</a>
        </div>
      </div>
    </div>
    <div class="mt-6 pt-4 border-t border-border flex justify-between text-[11px] text-text-light">
      <p>Not a diagnostic tool.</p>
      <p>&copy; {year} IsItAuDHD</p>
    </div>
  </div>
</footer>

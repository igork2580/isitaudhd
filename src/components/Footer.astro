---
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="max-w-3xl mx-auto px-5 py-10">
    <div class="flex flex-col sm:flex-row justify-between gap-8">
      <div>
        <p class="text-sm font-semibold text-text">IsItAuDHD</p>
        <p class="mt-1.5 text-xs text-text-light max-w-[220px] leading-relaxed">
          Free quizzes and resources for understanding the autism + ADHD overlap.
        </p>
      </div>

      <div class="flex gap-10 text-xs">
        <div class="space-y-2">
          <a href="/quiz/" class="block text-text-light hover:text-text transition-colors">Quizzes</a>
          <a href="/learn/" class="block text-text-light hover:text-text transition-colors">Learn</a>
          <a href="/blog/" class="block text-text-light hover:text-text transition-colors">Blog</a>
        </div>
        <div class="space-y-2">
          <a href="/about/" class="block text-text-light hover:text-text transition-colors">About</a>
          <a href="/newsletter/" class="block text-text-light hover:text-text transition-colors">Newsletter</a>
          <a href="/disclaimer/" class="block text-text-light hover:text-text transition-colors">Disclaimer</a>
          <a href="/privacy/" class="block text-text-light hover:text-text transition-colors">Privacy</a>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-5 border-t border-border flex flex-col sm:flex-row justify-between gap-2 text-xs text-text-light">
      <p>Not a diagnostic tool.</p>
      <p>&copy; {year} IsItAuDHD</p>
    </div>
  </div>
</footer>

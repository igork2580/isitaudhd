---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Free AuDHD quizzes to explore if you have both autism and ADHD. Understand the overlap, take self-assessments, and learn what AuDHD means for you."
>
  <!-- Hero -->
  <section class="max-w-3xl mx-auto px-5 pt-20 sm:pt-28 pb-16">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight leading-[1.1]">
      Is it autism, ADHD,<br />or both?
    </h1>
    <p class="mt-5 text-lg text-text-light max-w-lg leading-relaxed">
      Explore traits of AuDHD with free, research-informed quizzes.
      No account needed. Your answers stay on your device.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/quiz/is-it-audhd/" class="text-sm font-medium text-white bg-text px-5 py-2.5 rounded-md hover:bg-text/80 transition-colors">
        Take the AuDHD Quiz
      </a>
      <a href="/learn/what-is-audhd/" class="text-sm font-medium text-text-light border border-border px-5 py-2.5 rounded-md hover:border-text/30 hover:text-text transition-colors">
        What is AuDHD?
      </a>
    </div>
  </section>

  <!-- Quizzes -->
  <section class="max-w-3xl mx-auto px-5 py-12 border-t border-border">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-sm font-medium text-text-light uppercase tracking-wide">Quizzes</h2>
      <a href="/quiz/" class="text-sm text-text-light hover:text-text transition-colors">View all &rarr;</a>
    </div>

    <div class="space-y-1">
      {[
        { title: 'Is It AuDHD?', desc: 'Explore traits of both autism and ADHD', time: '5-8 min', count: 30, href: '/quiz/is-it-audhd/' },
        { title: 'Autism, ADHD, or Both?', desc: 'See where your traits lean', time: '4-6 min', count: 20, href: '/quiz/autism-or-adhd/' },
        { title: 'AuDHD Burnout Check', desc: 'Check for masking fatigue and executive shutdown', time: '3-5 min', count: 15, href: '/quiz/audhd-burnout/' },
        { title: 'Sensory Profile', desc: 'Map your sensory patterns', time: '4-5 min', count: 20, href: '/quiz/sensory-profile/' },
        { title: 'Masking Score', desc: 'How much are you masking?', time: '4-5 min', count: 20, href: '/quiz/masking-score/' },
        { title: 'Executive Function', desc: 'Check your task initiation and flexibility', time: '4-5 min', count: 18, href: '/quiz/executive-function/' },
        { title: 'Rejection Sensitivity', desc: 'Explore your rejection sensitivity patterns', time: '3-4 min', count: 15, href: '/quiz/rejection-sensitivity/' },
        { title: 'AuDHD at Work', desc: 'How is your brain handling the workplace?', time: '4-5 min', count: 18, href: '/quiz/audhd-at-work/' },
      ].map((quiz) => (
        <a href={quiz.href} class="flex items-center justify-between py-3 px-3 -mx-3 rounded-lg hover:bg-muted transition-colors group">
          <div class="min-w-0">
            <p class="text-sm font-medium text-text group-hover:text-primary transition-colors">{quiz.title}</p>
            <p class="text-xs text-text-light mt-0.5">{quiz.desc}</p>
          </div>
          <div class="flex items-center gap-3 text-xs text-text-light flex-shrink-0 ml-4">
            <span class="hidden sm:inline">{quiz.count}q</span>
            <span>{quiz.time}</span>
            <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity text-text-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- What is AuDHD -->
  <section class="max-w-3xl mx-auto px-5 py-12 border-t border-border">
    <h2 class="text-sm font-medium text-text-light uppercase tracking-wide mb-6">About AuDHD</h2>

    <div class="space-y-4 text-[15px] text-text-light leading-relaxed">
      <p>
        <strong class="text-text font-semibold">AuDHD</strong> is a community term for having both
        autism and ADHD. Research shows 30-50% of autistic people also meet criteria for ADHD.
        The combination creates experiences that are different from either alone.
      </p>
      <p>
        People with AuDHD often describe living with contradictions: craving routine but getting bored
        by it. Needing deep focus but unable to control where it goes. Wanting connection but finding
        it draining.
      </p>
    </div>

    <div class="mt-6 grid grid-cols-1 sm:grid-cols-3 gap-3">
      {[
        { label: 'Routine vs novelty', sub: 'Autism wants structure, ADHD wants change' },
        { label: 'Focus vs distraction', sub: 'Hyperfocus meets attention scatter' },
        { label: 'Social need vs overload', sub: 'Connection that comes at a cost' },
      ].map((item) => (
        <div class="border border-border rounded-lg p-3.5">
          <p class="text-sm font-medium text-text">{item.label}</p>
          <p class="text-xs text-text-light mt-1">{item.sub}</p>
        </div>
      ))}
    </div>

    <a href="/learn/what-is-audhd/" class="inline-block mt-5 text-sm text-text-light hover:text-text transition-colors">
      Read more about AuDHD &rarr;
    </a>
  </section>

  <!-- Learn -->
  <section class="max-w-3xl mx-auto px-5 py-12 border-t border-border">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-sm font-medium text-text-light uppercase tracking-wide">Learn</h2>
      <a href="/learn/" class="text-sm text-text-light hover:text-text transition-colors">View all &rarr;</a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        { title: 'Signs of AuDHD', href: '/learn/signs-of-audhd/' },
        { title: 'AuDHD in Women', href: '/learn/audhd-in-women/' },
        { title: 'Getting Assessed', href: '/learn/getting-assessed/' },
        { title: 'AuDHD and Burnout', href: '/learn/audhd-and-burnout/' },
      ].map((item) => (
        <a href={item.href} class="flex items-center justify-between border border-border rounded-lg px-4 py-3 hover:border-text/20 transition-colors group">
          <span class="text-sm font-medium text-text">{item.title}</span>
          <svg class="w-4 h-4 text-text-light opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 4.5l7.5 7.5-7.5 7.5"/></svg>
        </a>
      ))}
    </div>
  </section>

  <!-- Newsletter -->
  <section class="max-w-3xl mx-auto px-5 py-12 border-t border-border">
    <div class="bg-muted rounded-xl p-6 sm:p-8">
      <h2 class="text-base font-semibold text-text">AuDHD Insights</h2>
      <p class="mt-1.5 text-sm text-text-light">
        New quizzes, research digests, and practical strategies. Weekly.
      </p>
      <form class="flex gap-2 mt-4 max-w-sm" id="hero-newsletter">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-3.5 py-2 rounded-md border border-border bg-surface text-sm text-text focus:border-text/30 focus:outline-none"
        />
        <button type="submit" class="text-sm font-medium text-white bg-text px-4 py-2 rounded-md hover:bg-text/80 transition-colors flex-shrink-0">
          Subscribe
        </button>
      </form>
      <p class="text-xs text-text-light mt-2.5">Free. No spam. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- Trust -->
  <section class="max-w-3xl mx-auto px-5 py-12 border-t border-border">
    <div class="flex flex-col sm:flex-row gap-6 sm:gap-10 text-sm text-text-light">
      <div>
        <p class="font-medium text-text">Research-informed</p>
        <p class="mt-1">Quizzes grounded in current neurodivergence research.</p>
      </div>
      <div>
        <p class="font-medium text-text">Private</p>
        <p class="mt-1">Your answers stay on your device. Nothing sent to servers.</p>
      </div>
      <div>
        <p class="font-medium text-text">Sensory-friendly</p>
        <p class="mt-1">Clean design. No flashing. Dark mode included.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('hero-newsletter')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button');
    if (btn) { btn.textContent = 'Subscribed'; (btn as HTMLButtonElement).disabled = true; }
  });
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuizCard from '../components/QuizCard.astro';
---

<BaseLayout
  title="Home"
  description="Free AuDHD quizzes to explore if you have both autism and ADHD. Understand the overlap, take self-assessments, and learn what AuDHD means for you."
>
  <!-- Hero -->
  <section class="hero-glow">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-20 sm:pt-28 pb-16 text-center">
      <p class="section-label mb-6">
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none"><path d="M8 1C4.5 1 2 3.5 3 6s3 2.5 5 5c2-2.5 4-2 5-5s-1.5-5-5-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Free self-assessment quizzes
      </p>

      <h1 class="text-[2.75rem] sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.08]">
        Is it autism, ADHD,<br />
        <span class="gradient-text">or both?</span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-text-light max-w-xl mx-auto leading-relaxed">
        Explore traits of AuDHD with free, research-informed quizzes.
        No sign-up, no data collection, instant results.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/quiz/is-it-audhd/" class="btn-primary text-lg">
          Take the AuDHD Quiz
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
        <a href="/learn/what-is-audhd/" class="btn-secondary text-lg">
          What is AuDHD?
        </a>
      </div>

      <div class="mt-6 flex items-center justify-center gap-5 text-sm text-text-light">
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          5-8 minutes
        </span>
        <span class="w-1 h-1 rounded-full bg-border"></span>
        <span class="flex items-center gap-1.5">
          <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
          Private
        </span>
        <span class="w-1 h-1 rounded-full bg-border"></span>
        <span>Not a diagnosis</span>
      </div>
    </div>
  </section>

  <!-- Featured quizzes -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    <div class="flex items-center justify-between mb-8">
      <div>
        <p class="section-label mb-2">Quizzes</p>
        <h2 class="text-2xl sm:text-3xl font-bold text-text">Choose your quiz</h2>
      </div>
      <a href="/quiz/" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-primary hover:text-primary-dark transition-colors">
        View all
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <QuizCard
        title="Is It AuDHD?"
        description="Explore whether you show traits of both autism and ADHD. Our most comprehensive assessment."
        href="/quiz/is-it-audhd/"
        estimatedTime="5-8 min"
        questionCount={30}
        color="primary"
        featured={true}
      />
      <QuizCard
        title="Autism, ADHD, or Both?"
        description="Compare autism-typical and ADHD-typical patterns to see where your experience fits."
        href="/quiz/autism-or-adhd/"
        estimatedTime="4-6 min"
        questionCount={20}
        color="accent"
      />
      <QuizCard
        title="AuDHD Burnout Check"
        description="Check for masking fatigue, executive shutdown, and the kind of burnout sleep can't fix."
        href="/quiz/audhd-burnout/"
        estimatedTime="3-5 min"
        questionCount={15}
        color="secondary"
      />
    </div>

    <div class="mt-5 sm:hidden text-center">
      <a href="/quiz/" class="text-sm font-medium text-primary">View all 8 quizzes &rarr;</a>
    </div>
  </section>

  <!-- What is AuDHD -->
  <section class="bg-muted/60">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-10 items-center">
        <div>
          <p class="section-label mb-3">Understanding</p>
          <h2 class="text-2xl sm:text-3xl font-bold text-text leading-snug">
            What is AuDHD?
          </h2>
          <p class="mt-4 text-text-light leading-relaxed">
            AuDHD is a community term for having both autism and ADHD. Research shows
            30-50% of autistic people also meet criteria for ADHD, creating a unique
            experience different from either alone.
          </p>
          <a href="/learn/what-is-audhd/" class="inline-flex items-center gap-1.5 mt-5 text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
            Learn more
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="space-y-3">
          {[
            { text: 'Craving routine but getting bored by it', left: 'Autism', right: 'ADHD' },
            { text: 'Deep focus you can\'t control where it goes', left: 'Autism', right: 'ADHD' },
            { text: 'Wanting connection but finding it draining', left: 'Autism', right: 'ADHD' },
          ].map((item) => (
            <div class="card p-4">
              <p class="text-sm font-medium text-text">{item.text}</p>
              <div class="flex gap-2 mt-2">
                <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-primary/10 text-primary">{item.left}</span>
                <span class="text-[11px] text-text-light">+</span>
                <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-secondary/10 text-secondary">{item.right}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Trust signals -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="card p-6 text-center">
        <div class="icon-box bg-primary/10 text-primary mx-auto mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        </div>
        <h3 class="font-semibold text-text">Research-Informed</h3>
        <p class="text-sm text-text-light mt-1.5 leading-relaxed">Quizzes grounded in current neurodivergence research and validated screening approaches</p>
      </div>
      <div class="card p-6 text-center">
        <div class="icon-box bg-accent/10 text-accent-dark mx-auto mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <h3 class="font-semibold text-text">Private & Free</h3>
        <p class="text-sm text-text-light mt-1.5 leading-relaxed">No sign-up. Your answers stay on your device. Nothing is sent to any server.</p>
      </div>
      <div class="card p-6 text-center">
        <div class="icon-box bg-secondary/10 text-secondary mx-auto mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <h3 class="font-semibold text-text">Built for ND Brains</h3>
        <p class="text-sm text-text-light mt-1.5 leading-relaxed">Sensory-friendly design. No flashing, no clutter, dark mode included.</p>
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 pb-20">
    <div class="card p-8 sm:p-10 text-center" style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 4%, var(--color-surface)), color-mix(in srgb, var(--color-accent) 4%, var(--color-surface)));">
      <p class="section-label mb-3 justify-center">Stay updated</p>
      <h2 class="text-xl sm:text-2xl font-bold text-text">AuDHD Insights Newsletter</h2>
      <p class="mt-2 text-text-light text-sm max-w-md mx-auto">
        New quizzes, research digests, and practical strategies. Written for neurodivergent brains.
      </p>
      <form class="flex flex-col sm:flex-row gap-2.5 max-w-sm mx-auto mt-6" id="hero-newsletter">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 px-4 py-3 rounded-[--radius-md] border border-border bg-surface text-text text-sm focus:border-primary focus:outline-none"
        />
        <button type="submit" class="btn-primary text-sm !py-3 !px-6">Subscribe</button>
      </form>
      <p class="text-xs text-text-light mt-3">Free. No spam. Unsubscribe anytime.</p>
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('hero-newsletter')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = (e.target as HTMLFormElement).querySelector('button');
    if (btn) { btn.textContent = 'Subscribed!'; (btn as HTMLButtonElement).disabled = true; }
  });
</script>

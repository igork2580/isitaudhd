---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuizPlayer } from '../../components/quiz/QuizPlayer';
import quizData from '../../content/quizzes/masking-score.json';
---

<BaseLayout
  title="How Much Are You Masking? — Free AuDHD Quiz"
  description="Masking is exhausting. This free 20-question quiz explores how much you're hiding your neurodivergent traits and the toll it takes. Takes 4-5 minutes."
  breadcrumbs={[{ label: 'Quizzes', href: '/quiz/' }, { label: 'Masking Score', href: '/quiz/masking-score/' }]}
>
  <article class="max-w-2xl mx-auto px-5 py-12">
    <header class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">
        How Much Are You Masking?
      </h1>
      <p class="mt-3 text-[0.9375rem] text-text-light leading-relaxed max-w-lg">
        Explore how much you hide your neurodivergent traits and the toll it takes. 20 questions, takes about 5 minutes. Your answers stay private.
      </p>
    </header>
    <QuizPlayer quiz={quizData} client:load />
  </article>
</BaseLayout>

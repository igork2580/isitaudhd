---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuizCard from '../../components/QuizCard.astro';
---

<BaseLayout
  title="AuDHD Quizzes"
  description="Free quizzes to explore AuDHD traits — the overlap of autism and ADHD. Self-assessments for burnout, masking, sensory processing, executive function, and more."
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-text">AuDHD Quizzes</h1>
      <p class="mt-4 text-lg text-text-light max-w-2xl mx-auto">
        Explore different aspects of the autism + ADHD overlap. Each quiz takes
        just a few minutes and your results are instant.
      </p>
    </div>

    <!-- Featured quiz -->
    <div class="mb-8">
      <QuizCard
        title="Is It AuDHD?"
        description="Our flagship quiz. Explore whether you show traits of both autism and ADHD — the hallmark of AuDHD. 30 questions covering autism traits, ADHD traits, and the unique overlap."
        href="/quiz/is-it-audhd/"
        estimatedTime="5-8 min"
        questionCount={30}
        emoji="🧠"
        featured={true}
      />
    </div>

    <!-- All quizzes grid -->
    <h2 class="text-xl font-bold text-text mb-5">All Quizzes</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <QuizCard
        title="Autism, ADHD, or Both?"
        description="Not sure which one fits? Compare autism-typical and ADHD-typical experiences to see where you lean."
        href="/quiz/autism-or-adhd/"
        estimatedTime="4-6 min"
        questionCount={20}
        emoji="🎭"
      />
      <QuizCard
        title="AuDHD Burnout Check"
        description="Neurodivergent burnout hits different. Check for masking fatigue, executive shutdown, and emotional exhaustion."
        href="/quiz/audhd-burnout/"
        estimatedTime="3-5 min"
        questionCount={15}
        emoji="🔥"
      />
      <QuizCard
        title="Sensory Profile"
        description="Are you a sensory seeker, avoider, or the chaotic mix of both? Map your AuDHD sensory patterns."
        href="/quiz/sensory-profile/"
        estimatedTime="4-5 min"
        questionCount={20}
        emoji="🌊"
      />
      <QuizCard
        title="Masking Score"
        description="How much are you hiding your neurodivergent traits? Explore social masking, behavioral masking, and its cost."
        href="/quiz/masking-score/"
        estimatedTime="4-5 min"
        questionCount={20}
        emoji="🎭"
      />
      <QuizCard
        title="Executive Function Check"
        description="The AuDHD executive function paradox: wanting perfect plans but never executing them. How's yours?"
        href="/quiz/executive-function/"
        estimatedTime="4-5 min"
        questionCount={18}
        emoji="⚡"
      />
      <QuizCard
        title="Rejection Sensitivity"
        description="When literal interpretation meets emotional dysregulation, rejection feels devastating. Check your patterns."
        href="/quiz/rejection-sensitivity/"
        estimatedTime="3-4 min"
        questionCount={15}
        emoji="💔"
      />
      <QuizCard
        title="AuDHD at Work"
        description="Open offices, meetings, context-switching — how is your AuDHD brain handling the modern workplace?"
        href="/quiz/audhd-at-work/"
        estimatedTime="4-5 min"
        questionCount={18}
        emoji="💼"
      />
    </div>

    <div class="mt-12 bg-accent/10 rounded-[--radius-xl] p-6 sm:p-8 text-center">
      <p class="text-text-light leading-relaxed">
        These quizzes are for self-exploration only and are not diagnostic tools.
        If your results resonate with you, we encourage you to speak with a qualified
        mental health professional who specializes in neurodivergence.
      </p>
      <a href="/learn/getting-assessed/" class="inline-block mt-3 text-primary hover:text-primary-dark font-medium transition-colors">
        How to get assessed for AuDHD &rarr;
      </a>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuizPlayer } from '../../components/quiz/QuizPlayer';
import quizData from '../../content/quizzes/sensory-profile.json';
---

<BaseLayout
  title="AuDHD Sensory Profile Quiz — Free Assessment"
  description="Explore your sensory patterns with this free quiz. Are you a sensory seeker, avoider, or the chaotic mix that defines AuDHD? Takes 4-5 minutes."
  breadcrumbs={[{ label: 'Quizzes', href: '/quiz/' }, { label: 'Sensory Profile', href: '/quiz/sensory-profile/' }]}
>
  <article class="max-w-2xl mx-auto px-5 py-12">
    <header class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">
        AuDHD Sensory Profile
      </h1>
      <p class="mt-3 text-[0.9375rem] text-text-light leading-relaxed max-w-lg">
        Map your sensory patterns -- seeking, avoiding, or the chaotic mix of both. 20 questions, takes about 5 minutes. Your answers stay private.
      </p>
    </header>
    <QuizPlayer quiz={quizData} client:load />
  </article>
</BaseLayout>

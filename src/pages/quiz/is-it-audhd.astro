---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuizPlayer } from '../../components/quiz/QuizPlayer';
import quizData from '../../content/quizzes/is-it-audhd.json';

const schema = {
  "@context": "https://schema.org",
  "@type": "Quiz",
  "name": "Is It AuDHD? — Free Self-Assessment Quiz",
  "description": "A free 30-question self-assessment quiz exploring traits of both autism and ADHD (AuDHD).",
  "educationalAlignment": { "@type": "AlignmentObject", "alignmentType": "educationalSubject", "targetName": "Neurodivergence" },
  "about": { "@type": "MedicalCondition", "name": "AuDHD (Autism + ADHD)" },
  "numberOfQuestions": quizData.questions.length,
  "hasPart": quizData.questions.slice(0, 5).map((q, i) => ({
    "@type": "Question",
    "position": i + 1,
    "text": q.text,
  })),
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What does this AuDHD quiz measure?", "acceptedAnswer": { "@type": "Answer", "text": "This quiz explores three areas: autism traits, ADHD traits, and overlap traits — the unique patterns that emerge when both are present." }},
    { "@type": "Question", "name": "Is this AuDHD quiz a diagnosis?", "acceptedAnswer": { "@type": "Answer", "text": "No. This quiz is a self-exploration tool, not a clinical assessment. Only a qualified professional can provide a diagnosis." }},
    { "@type": "Question", "name": "Who is this AuDHD quiz for?", "acceptedAnswer": { "@type": "Answer", "text": "This quiz is for adults who suspect they might have traits of both autism and ADHD, especially if diagnosed with one but suspecting the other." }},
  ],
};
---

<BaseLayout
  title="Is It AuDHD? — Free Self-Assessment Quiz"
  description="Take this free 30-question quiz to explore whether you show traits of both autism and ADHD (AuDHD). Takes 5-8 minutes. Instant results."
  schema={schema}
  breadcrumbs={[{ label: 'Quizzes', href: '/quiz/' }, { label: 'Is It AuDHD?', href: '/quiz/is-it-audhd/' }]}
>
  <article class="max-w-2xl mx-auto px-5 py-12">
    <header class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">
        Is It AuDHD?
      </h1>
      <p class="mt-3 text-[0.9375rem] text-text-light leading-relaxed max-w-lg">
        Explore whether you show traits of both autism and ADHD. 30 questions, takes about {quizData.estimatedTime}. Your answers stay private.
      </p>
    </header>

    <!-- Quiz player (React island) -->
    <QuizPlayer quiz={quizData} client:load />

    <!-- SEO content below quiz -->
    <section class="mt-16 pt-10 border-t border-border space-y-6 text-[0.9375rem]">
      <div>
        <h2 class="text-base font-semibold text-text mb-2">What does this quiz measure?</h2>
        <p class="text-text-light leading-relaxed">
          This quiz explores autism traits (social communication, sensory sensitivities, need for routine),
          ADHD traits (attention regulation, impulsivity, restlessness), and overlap traits — the patterns
          that emerge when both are present.
        </p>
      </div>
      <div>
        <h2 class="text-base font-semibold text-text mb-2">Who is this for?</h2>
        <p class="text-text-light leading-relaxed">
          Adults who suspect they might have traits of both autism and ADHD. Especially relevant if you've
          been diagnosed with one but suspect the other, or if you've never been assessed but relate to
          AuDHD experiences.
        </p>
      </div>
      <div>
        <h2 class="text-base font-semibold text-text mb-2">Is this a diagnosis?</h2>
        <p class="text-text-light leading-relaxed">
          No. This is a self-exploration tool. If your results resonate, consider speaking with a
          psychologist or psychiatrist who understands how autism and ADHD co-occur.
        </p>
      </div>
    </section>

    <!-- FAQ Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </article>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuizPlayer } from '../../components/quiz/QuizPlayer';
import quizData from '../../content/quizzes/audhd-at-work.json';
---

<BaseLayout
  title="AuDHD at Work — Free Workplace Quiz"
  description="Open offices, meetings, context-switching, office politics — work with AuDHD is a minefield. This free quiz explores your workplace challenges."
  breadcrumbs={[{ label: 'Quizzes', href: '/quiz/' }, { label: 'AuDHD at Work', href: '/quiz/audhd-at-work/' }]}
>
  <article class="max-w-2xl mx-auto px-5 py-12">
    <header class="mb-10">
      <h1 class="text-2xl sm:text-3xl font-bold text-text">
        AuDHD at Work
      </h1>
      <p class="mt-3 text-[0.9375rem] text-text-light leading-relaxed max-w-lg">
        Explore your workplace challenges with open offices, meetings, and context-switching. 18 questions, takes about 5 minutes. Your answers stay private.
      </p>
    </header>
    <QuizPlayer quiz={quizData} client:load />
  </article>
</BaseLayout>

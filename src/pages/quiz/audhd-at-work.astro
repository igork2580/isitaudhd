---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { QuizPlayer } from '../../components/quiz/QuizPlayer';
import quizData from '../../content/quizzes/audhd-at-work.json';
---

<BaseLayout
  title="AuDHD at Work — Free Workplace Quiz"
  description="Open offices, meetings, context-switching, office politics — work with AuDHD is a minefield. This free quiz explores your workplace challenges."
  breadcrumbs={[{ label: 'Quizzes', href: '/quiz/' }, { label: 'AuDHD at Work', href: '/quiz/audhd-at-work/' }]}
>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <header class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-text">
        AuDHD <span class="text-primary">at Work</span>
      </h1>
      <p class="mt-4 text-lg text-text-light max-w-2xl mx-auto leading-relaxed">
        The modern workplace can feel like it was designed to challenge every AuDHD trait at once: open offices for the sensory-sensitive, constant meetings for the socially drained, and endless context-switching for the executive-function-challenged. How are you holding up?
      </p>
      <div class="flex items-center justify-center gap-4 mt-4 text-sm text-text-light">
        <span>🕐 {quizData.estimatedTime}</span>
        <span class="w-1 h-1 rounded-full bg-border"></span>
        <span>📝 {quizData.questions.length} questions</span>
      </div>
    </header>
    <QuizPlayer quiz={quizData} client:load />
  </article>
</BaseLayout>

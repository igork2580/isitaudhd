---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    title: 'What Is AuDHD?',
    description: 'The term, the research, and what it actually feels like to have both autism and ADHD running at the same time.',
    href: '/learn/what-is-audhd/',
  },
  {
    title: 'Signs of AuDHD',
    description: 'Contradictory traits, sensory chaos, social exhaustion, and the internal tug-of-war that defines the AuDHD experience.',
    href: '/learn/signs-of-audhd/',
  },
  {
    title: 'AuDHD vs Autism',
    description: 'How adding ADHD to autism changes everything: routines, social behavior, sensory needs, and executive function.',
    href: '/learn/audhd-vs-autism/',
  },
  {
    title: 'AuDHD vs ADHD',
    description: 'Why standard ADHD strategies fall short when autism is in the mix, and what to do about it.',
    href: '/learn/audhd-vs-adhd/',
  },
  {
    title: 'AuDHD in Women',
    description: 'Why women get diagnosed decades late, how masking hides AuDHD, and what hormonal changes have to do with it.',
    href: '/learn/audhd-in-women/',
  },
  {
    title: 'AuDHD and Burnout',
    description: 'Why AuDHD burnout is different from regular burnout, how to recognize the warning signs, and what recovery actually looks like.',
    href: '/learn/audhd-and-burnout/',
  },
  {
    title: 'Getting Assessed for AuDHD',
    description: 'How to find the right professional, what to expect from an assessment, how to prepare, and what it costs.',
    href: '/learn/getting-assessed/',
  },
  {
    title: 'After Your Quiz: Next Steps',
    description: 'You took the quiz and scored high. Now what? A practical guide for what to do with your results.',
    href: '/learn/after-your-quiz/',
  },
];
---

<BaseLayout
  title="Learn About AuDHD"
  description="Articles about AuDHD (autism + ADHD): what it is, common signs, how it differs from autism or ADHD alone, and why women are underdiagnosed."
>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-text">Learn About AuDHD</h1>
      <p class="mt-4 text-lg text-text-light leading-relaxed">
        AuDHD is what happens when autism and ADHD coexist in the same brain. These articles break down what that means, how to recognize it, and why it matters.
      </p>
    </header>

    <div class="space-y-4">
      {articles.map((article) => (
        <a
          href={article.href}
          class="block p-6 rounded-[--radius-xl] border border-border hover:border-primary/40 hover:bg-accent/5 transition-all group"
        >
          <h2 class="text-xl font-bold text-text group-hover:text-primary transition-colors">
            {article.title}
          </h2>
          <p class="mt-2 text-text-light leading-relaxed">
            {article.description}
          </p>
          <span class="inline-block mt-3 text-primary text-sm font-medium">
            Read article &rarr;
          </span>
        </a>
      ))}
    </div>

    <div class="mt-12 bg-accent/10 rounded-[--radius-xl] p-6 sm:p-8">
      <h3 class="font-semibold text-text mb-3">Not sure where to start?</h3>
      <p class="text-text-light leading-relaxed mb-4">
        Our quizzes are a quick way to explore whether AuDHD patterns match your experience.
      </p>
      <ul class="space-y-2">
        <li><a href="/quiz/is-it-audhd/" class="text-primary hover:text-primary-dark transition-colors">Take the AuDHD Quiz &rarr;</a></li>
        <li><a href="/quiz/autism-or-adhd/" class="text-primary hover:text-primary-dark transition-colors">Autism, ADHD, or Both? &rarr;</a></li>
      </ul>
    </div>
  </section>
</BaseLayout>
